# Vercel Postgres / Neon Database Configuration
# 
# IMPORTANT: Add this to your .env.local file (DO NOT commit this to GitHub!)
# 
# Steps:
# 1. Go to Vercel Dashboard → Storage → Your Database
# 2. Click .env.local tab
# 3. Show secret and copy the connection string
# 4. Paste below (replace the placeholder)

# For Vercel Postgres (deprecated, use Neon instead)
# DATABASE_URL=postgres://...

# For Neon (recommended)
# DATABASE_URL=postgresql://user:password@ep-xxx-xxx-123456.us-east-2.aws.neon.tech/neondb?sslmode=require
