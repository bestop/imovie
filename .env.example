# Neon Database Configuration
#
# 1. Go to https://console.neon.tech/ and create a database
# 2. Copy the connection string from the dashboard
# 3. Create a .env.local file in the project root and paste the connection string
#
# IMPORTANT: .env.local is ignored by git and should NEVER be committed

# Pooled connection (recommended for serverless/Vercel)
DATABASE_URL=postgresql://user:password@ep-xxx-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Direct connection (without pgbouncer, for migrations or long-running queries)
# DATABASE_URL_UNPOOLED=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
